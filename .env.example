# Example Environment Configuration
# Copy this file to .env.development or .env.production and fill in your values
# NEVER commit real credentials to git!

NODE_ENV=development

# Server
PORT=3050
API_URL=http://localhost:3050
FRONTEND_URL=http://localhost:3050

# Database
# For production with auth: mongodb://username:password@host:port/dbname?authSource=admin
MONGODB_URL=mongodb://localhost:27017/worldcup2026

# Live score provider
# Point this at your existing live score API or proxy that returns match data.
LIVE_SCORE_PROVIDER_URL=https://your-live-provider.example.com/matches
# Optional JSON object for provider headers, for example:
# {"x-api-key":"your_key_here","x-api-host":"provider.example.com"}
LIVE_SCORE_HEADERS_JSON={}
# Optional JSON object for static provider query params.
LIVE_SCORE_QUERY_JSON={}
# Optional response array path, for example "response" or "data.matches"
LIVE_SCORE_RESPONSE_PATH=
# Optional provider date filter support. If your provider accepts dates, set these.
LIVE_SCORE_DATE_QUERY_PARAM=date
LIVE_SCORE_DATE_QUERY_MODE=comma
# Field path mapping from provider payload into local game fields.
LIVE_SCORE_FIELD_ID=id
LIVE_SCORE_FIELD_HOME_SCORE=home_score
LIVE_SCORE_FIELD_AWAY_SCORE=away_score
LIVE_SCORE_FIELD_HOME_SCORERS=home_scorers
LIVE_SCORE_FIELD_AWAY_SCORERS=away_scorers
LIVE_SCORE_FIELD_FINISHED=finished
LIVE_SCORE_FIELD_TIME_ELAPSED=time_elapsed
LIVE_SCORE_FIELD_HOME_TEAM_ID=home_team_id
LIVE_SCORE_FIELD_AWAY_TEAM_ID=away_team_id
LIVE_SCORE_FIELD_HOME_TEAM_LABEL=home_team_label
LIVE_SCORE_FIELD_AWAY_TEAM_LABEL=away_team_label
# Polling windows
LIVE_SCORE_POLL_INTERVAL_MS=60000
LIVE_SCORE_PREMATCH_WINDOW_MS=900000
LIVE_SCORE_POSTMATCH_WINDOW_MS=14400000
LIVE_SCORE_MAX_IDLE_SLEEP_MS=1800000
LIVE_SCORE_REQUEST_TIMEOUT_MS=15000

# Security - Generate strong random keys for production!
JWT_SECRET=your_jwt_secret_key_here
SECRET=your_secret_key_here
ACESSCODEDEV=your_admin_access_code

# Logging (debug, info, warn, error)
LOG_LEVEL=debug

# Swagger Documentation (true/false - always enabled in development)
ENABLE_SWAGGER=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX=300

# CORS (use * for development, specific origins for production)
CORS_ORIGINS=*

# NOWPayments - Crypto Payment Gateway (https://nowpayments.io)
# Get your API keys from: https://account.nowpayments.io/
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_PUBLIC_KEY=your_nowpayments_public_key
DONATION_WALLET_ADDRESS=your_trc20_wallet_address
